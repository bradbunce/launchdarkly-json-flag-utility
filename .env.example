# LaunchDarkly API Key (required for flag management)
LD_API_KEY=api-12345

# LaunchDarkly SDK Key (required for AI Configs in web UI)
LD_SDK_KEY=sdk-your-sdk-key

# Default project (optional - web UI has a project selector, CLI will prompt if not set)
# LD_PROJECT_KEY=your-project-key

# AWS Bedrock - uses default AWS CLI profile (aws configure) by default.
# Only set these if you need to override:
# AWS_REGION=us-east-1
# AWS_PROFILE=your-profile-name
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
